rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId);
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId); // Initial empty profile creation
      allow update: if isOwner(userId) && (
        // Action: Complete Onboarding/Edit
        incoming().diff(existing()).affectedKeys().hasAny(['name', 'age', 'weight', 'height', 'bloodType', 'allergies', 'medications', 'conditions', 'isProfileComplete', 'updatedAt'])
      );

      // --- Sub-collections ---
      match /symptoms/{symptomId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /reminders/{reminderId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /journal/{entryId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /lab_results/{resultId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
